{
    "name": "nishadtaylor1/qti-sdk",
    "description": "A dependency-free PHP SDK for authoring IMS QTI 2.2 assessment items and content packages, with pluggable target-platform import profiles",
    "type": "library",
    "license": "MIT",
    "keywords": ["qti", "ims", "1edtech", "assessment", "edtech", "content-package", "imsmanifest"],
    "require": {
        "php": ">=8.1",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": { "QtiSdk\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "QtiSdk\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit --colors=always tests"
    }
}
